# '/' 요청 시 index.php를 우선 사용 (언어별 서버사이드 메타태그 렌더링을 위해)
DirectoryIndex index.php index.html

# 텍스트 파일(robots.txt, ads.txt 등)에 UTF-8 charset을 명시적으로 붙임
# 이게 없으면 브라우저가 인코딩을 잘못 추측해서 한글이 깨져 보일 수 있음
AddDefaultCharset UTF-8

# XML MIME 타입 (sitemap.xml이 텍스트로 깨져 보이는 문제 해결)
AddType application/xml .xml
AddType text/plain .txt

# ═══════════════════════════════════════════════════════════════
#  정적 자산 캐시 (트래픽 절감 핵심)
#  - 지금까지 캐시 헤더가 없어 app.js(94KB)·아이콘 등이 페이지마다 재다운로드됐음.
#  - 이미지·폰트: 거의 안 바뀌므로 30일 캐시(immutable).
#  - JS·CSS: 배포 반영 위해 1일. (즉시 반영 필요하면 파일 참조에 ?v=날짜 붙이기)
#  - PHP/HTML: 동적이라 여기서 건드리지 않음(각 PHP가 알아서 처리, gzip은 서버가 자동).
# ═══════════════════════════════════════════════════════════════
# ═══════════════════════════════════════════════════════════════
#  동적 응답 gzip 압축 (api.php JSON·sitemap XML·RSS 등)
#  - Cafe24 기본 gzip은 text/html만 걸려서, api.php(JSON 4.3KB)가 비압축으로 나갔음.
#  - JSON·XML·RSS 압축 시 api.php ~4배↓ (136MB → ~34MB 수준).
# ═══════════════════════════════════════════════════════════════
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE application/json application/javascript text/javascript text/css application/xml text/xml application/rss+xml application/atom+xml image/svg+xml text/plain
</IfModule>

<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/png              "access plus 30 days"
  ExpiresByType image/jpeg             "access plus 30 days"
  ExpiresByType image/gif              "access plus 30 days"
  ExpiresByType image/webp             "access plus 30 days"
  ExpiresByType image/svg+xml          "access plus 30 days"
  ExpiresByType image/x-icon           "access plus 30 days"
  ExpiresByType font/woff2             "access plus 30 days"
  ExpiresByType font/woff              "access plus 30 days"
  ExpiresByType application/font-woff  "access plus 30 days"
  ExpiresByType application/javascript "access plus 1 day"
  ExpiresByType text/javascript        "access plus 1 day"
  ExpiresByType text/css               "access plus 1 day"
</IfModule>
<IfModule mod_headers.c>
  # 이미지·폰트·아이콘: 오래 + immutable (재검증도 안 함)
  <FilesMatch "\.(png|jpe?g|gif|webp|svg|ico|woff2?)$">
    Header set Cache-Control "public, max-age=2592000, immutable"
  </FilesMatch>
  # JS·CSS: 1일 캐시 (세션 내 여러 페이지에서 app.js 재다운로드 방지)
  <FilesMatch "\.(js|css)$">
    Header set Cache-Control "public, max-age=86400"
  </FilesMatch>
</IfModule>

# ═══════════════════════════════════════════════════════════════
#  ★ 2026-07-15 보안 패치
# ═══════════════════════════════════════════════════════════════
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=(), usb=()"
</IfModule>

# include 전용 PHP — 웹에서 직접 호출할 이유가 없다(require_once 로만 쓰임).
# 지금은 빈 200 을 주지만, 서버가 PHP 파싱에 실패하는 순간 소스가 그대로 노출된다.
# (플로팅 위젯은 same-origin iframe 이라 X-Frame-Options SAMEORIGIN 에 영향 없음)
<FilesMatch "^(config|config_secret|data_sources|score_calc|glossary_data|_category_meta|_settings_modal|_nav_btns|_shared_footer|_guide_head|_guide_foot)\.php$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order allow,deny
    Deny from all
  </IfModule>
</FilesMatch>

# /privacy, /terms → 내부적으로 .php가 응답 (URL은 그대로 유지)
# (구 버전은 privacy.html로 301 리다이렉트했으나, .php 전환으로 rewrite 처리)
RewriteEngine On

# www 접속을 www 없는 주소로 301 리다이렉트 (SEO 중복 방지).
# canonical·사이트맵이 모두 www 없는 https://btctiming.com 기준이므로 통일한다.
# %1 = www를 둔 나머지 도메인. non-www엔 www가 없어 무한루프 없음.
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [R=301,L]

# ═══ 301: 기존 URL → 경로형 clean URL (THE_REQUEST로 외부 요청만 잡아 루프 방지) ═══
# (1) 블로그 글 비-ko: /blog/slug.php?lang=xx → /xx/blog/slug
RewriteCond %{THE_REQUEST} \s/blog/([a-z0-9-]+)\.php\?lang=(en|ja|es|de|fr|pt|tr|vi)[\s&] [NC]
RewriteRule ^blog/([a-z0-9-]+)\.php$ /%2/blog/%1? [R=301,L]
# (2) 블로그 글 ko: /blog/slug.php → /blog/slug  (?lang= 없는 순수 .php만)
RewriteCond %{THE_REQUEST} \s/blog/([a-z0-9-]+)\.php\s [NC]
RewriteRule ^blog/([a-z0-9-]+)\.php$ /blog/%1 [R=301,L]
# (3) 홈 비-ko: /?lang=xx → /xx
RewriteCond %{THE_REQUEST} \s/\?lang=(en|ja|es|de|fr|pt|tr|vi)[\s&] [NC]
RewriteRule ^$ /%1? [R=301,L]
# (4) 블로그 목록 비-ko: /blog/?lang=xx → /xx/blog/  (ajax 요청 제외)
RewriteCond %{THE_REQUEST} \s/blog/\?lang=(en|ja|es|de|fr|pt|tr|vi)[\s&] [NC]
RewriteCond %{QUERY_STRING} !ajax=
RewriteRule ^blog/$ /%1/blog/? [R=301,L]
# (5) 용어집 지표 비-ko: /glossary/term?lang=xx → /xx/glossary/term
RewriteCond %{THE_REQUEST} \s/glossary/([a-z0-9-]+)\?lang=(en|ja|es|de|fr|pt|tr|vi)[\s&] [NC]
RewriteRule ^glossary/([a-z0-9-]+)$ /%2/glossary/%1? [R=301,L]
# (6) 용어집 허브 비-ko: /glossary?lang=xx → /xx/glossary
RewriteCond %{THE_REQUEST} \s/glossary\?lang=(en|ja|es|de|fr|pt|tr|vi)[\s&] [NC]
RewriteRule ^glossary$ /%1/glossary? [R=301,L]
# (7) 정적/안내 비-ko: /page?lang=xx → /xx/page
RewriteCond %{THE_REQUEST} \s/(about|privacy|terms|exchanges|coins|rss-guide|sitemap-guide)\?lang=(en|ja|es|de|fr|pt|tr|vi)[\s&] [NC]
RewriteRule ^(about|privacy|terms|exchanges|coins|rss-guide|sitemap-guide)$ /%2/%1? [R=301,L]

# (7b) 정적/안내 .php → clean : /rss-guide.php → /rss-guide , .php?lang=xx → /xx/page
RewriteCond %{THE_REQUEST} \s/(about|privacy|terms|exchanges|coins|rss-guide|sitemap-guide|glossary)\.php\?lang=(en|ja|es|de|fr|pt|tr|vi)[\s&] [NC]
RewriteRule ^(about|privacy|terms|exchanges|coins|rss-guide|sitemap-guide|glossary)\.php$ /%2/%1? [R=301,L]
RewriteCond %{THE_REQUEST} \s/(about|privacy|terms|exchanges|coins|rss-guide|sitemap-guide|glossary)\.php\s [NC]
RewriteRule ^(about|privacy|terms|exchanges|coins|rss-guide|sitemap-guide|glossary)\.php$ /%1 [R=301,L]

# (8) 경로에 이미 언어가 있는데 ?lang= 이 중복으로 붙은 경우 → ?lang= 제거 (예: /pt?lang=pt → /pt)
RewriteCond %{THE_REQUEST} \s/(en|ja|es|de|fr|pt|tr|vi)(?:/[^\s?]*)?\?lang=[a-z]{2}[\s&] [NC]
RewriteRule ^(en|ja|es|de|fr|pt|tr|vi)(/.*)?$ /$1$2? [R=301,L]

RewriteRule ^privacy/?$ /privacy.php [L]
RewriteRule ^about/?$ /about.php [L]
RewriteRule ^glossary/([a-z0-9-]+)/?$ /glossary.php?term=$1 [L,QSA]
RewriteRule ^glossary/?$ /glossary.php [L,QSA]
RewriteRule ^terms/?$ /terms.php [L]

# 구주소 접근 시 새 주소로 정리 (.html 캐시된 링크 대응)
RewriteRule ^privacy\.html$ /privacy [R=301,L]
RewriteRule ^terms\.html$ /terms [R=301,L]

# sitemap.xml 주소로 접근해도 실제로는 sitemap.php가 응답 (검색엔진 호환성)
# 사용자/구글 눈에는 https://btctiming.com/sitemap.xml 로 보이지만
# 내부적으로는 계속 PHP로 동적 생성되는 sitemap.php가 처리합니다.
RewriteRule ^sitemap\.xml$ /sitemap.php [L]

# 블로그 아티클 구주소(.html) → 신주소(.php) 301 리다이렉트
# 예: /blog/mvrv-z-score.html → /blog/mvrv-z-score.php
# 새 글이 추가돼도 이 규칙 하나로 전부 자동 처리됩니다 (수정 불필요)
RewriteRule ^blog/([a-z0-9-]+)\.html$ /blog/$1.php [R=301,L]

# ═══ 언어 최상위 경로형 URL (비-ko). 내부적으로 ?lang= 를 넘겨 기존 렌더가 처리 ═══
#   /en, /en/blog/, /en/blog/{slug}, /en/glossary/{term} … (ko는 접두어 없이 기존 그대로)
#   ?lang= 도 계속 동작 → 아무것도 안 깨짐. 구체 규칙(blog/glossary)을 홈 규칙보다 먼저 둔다.
RewriteRule ^(en|ja|es|de|fr|pt|tr|vi)/blog/([a-z0-9-]+)(?:\.php)?/?$ /blog/$2.php?lang=$1 [L,QSA]
RewriteRule ^(en|ja|es|de|fr|pt|tr|vi)/blog/?$ /blog/index.php?lang=$1 [L,QSA]
RewriteRule ^(en|ja|es|de|fr|pt|tr|vi)/glossary/([a-z0-9-]+)/?$ /glossary.php?term=$2&lang=$1 [L,QSA]
RewriteRule ^(en|ja|es|de|fr|pt|tr|vi)/glossary/?$ /glossary.php?lang=$1 [L,QSA]
# 홈: /en, /ja … (실제 파일/폴더가 아닐 때만)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(en|ja|es|de|fr|pt|tr|vi)/?$ /index.php?lang=$1 [L,QSA]

# 언어 최상위 - 정적/안내 페이지 (about, privacy, terms, exchanges, coins, rss-guide, sitemap-guide)
RewriteRule ^(en|ja|es|de|fr|pt|tr|vi)/(about|privacy|terms|exchanges|coins|rss-guide|sitemap-guide)/?$ /$2.php?lang=$1 [L,QSA]

# ═══ ko clean 내부 라우팅: /blog/slug → /blog/slug.php , /exchanges 등 → .php ═══
# (.php·언어경로 아닌 순수 clean URL을 실제 파일로 매핑. about/privacy/terms/glossary는 위 기존 규칙 사용)
RewriteRule ^blog/([a-z0-9-]+)/?$ /blog/$1.php [L,QSA]
RewriteRule ^(exchanges|coins|rss-guide|sitemap-guide)/?$ /$1.php [L,QSA]

