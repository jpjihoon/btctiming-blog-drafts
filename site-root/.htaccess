# '/' 요청 시 index.php를 우선 사용 (언어별 서버사이드 메타태그 렌더링을 위해)
DirectoryIndex index.php index.html

# 텍스트 파일(robots.txt, ads.txt 등)에 UTF-8 charset을 명시적으로 붙임
# 이게 없으면 브라우저가 인코딩을 잘못 추측해서 한글이 깨져 보일 수 있음
AddDefaultCharset UTF-8

# XML MIME 타입 (sitemap.xml이 텍스트로 깨져 보이는 문제 해결)
AddType application/xml .xml
AddType text/plain .txt

# /privacy, /terms → 내부적으로 .php가 응답 (URL은 그대로 유지)
# (구 버전은 privacy.html로 301 리다이렉트했으나, .php 전환으로 rewrite 처리)
RewriteEngine On

# www 접속을 www 없는 주소로 301 리다이렉트 (SEO 중복 방지).
# canonical·사이트맵이 모두 www 없는 https://btctiming.com 기준이므로 통일한다.
# %1 = www를 둔 나머지 도메인. non-www엔 www가 없어 무한루프 없음.
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [R=301,L]

RewriteRule ^privacy/?$ /privacy.php [L]
RewriteRule ^about/?$ /about.php [L]
RewriteRule ^glossary/([a-z0-9-]+)/?$ /glossary.php?term=$1 [L,QSA]
RewriteRule ^glossary/?$ /glossary.php [L,QSA]
RewriteRule ^terms/?$ /terms.php [L]

# 구주소 접근 시 새 주소로 정리 (.html 캐시된 링크 대응)
RewriteRule ^privacy\.html$ /privacy [R=301,L]
RewriteRule ^terms\.html$ /terms [R=301,L]

# sitemap.xml 주소로 접근해도 실제로는 sitemap.php가 응답 (검색엔진 호환성)
# 사용자/구글 눈에는 https://btctiming.com/sitemap.xml 로 보이지만
# 내부적으로는 계속 PHP로 동적 생성되는 sitemap.php가 처리합니다.
RewriteRule ^sitemap\.xml$ /sitemap.php [L]

# 블로그 아티클 구주소(.html) → 신주소(.php) 301 리다이렉트
# 예: /blog/mvrv-z-score.html → /blog/mvrv-z-score.php
# 새 글이 추가돼도 이 규칙 하나로 전부 자동 처리됩니다 (수정 불필요)
RewriteRule ^blog/([a-z0-9-]+)\.html$ /blog/$1.php [R=301,L]

# ═══ 언어 최상위 경로형 URL (비-ko). 내부적으로 ?lang= 를 넘겨 기존 렌더가 처리 ═══
#   /en, /en/blog/, /en/blog/{slug}, /en/glossary/{term} … (ko는 접두어 없이 기존 그대로)
#   ?lang= 도 계속 동작 → 아무것도 안 깨짐. 구체 규칙(blog/glossary)을 홈 규칙보다 먼저 둔다.
RewriteRule ^(en|ja|es|de|fr|pt|tr|vi)/blog/([a-z0-9-]+)(?:\.php)?/?$ /blog/$2.php?lang=$1 [L,QSA]
RewriteRule ^(en|ja|es|de|fr|pt|tr|vi)/blog/?$ /blog/index.php?lang=$1 [L,QSA]
RewriteRule ^(en|ja|es|de|fr|pt|tr|vi)/glossary/([a-z0-9-]+)/?$ /glossary.php?term=$2&lang=$1 [L,QSA]
RewriteRule ^(en|ja|es|de|fr|pt|tr|vi)/glossary/?$ /glossary.php?lang=$1 [L,QSA]
# 홈: /en, /ja … (실제 파일/폴더가 아닐 때만)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(en|ja|es|de|fr|pt|tr|vi)/?$ /index.php?lang=$1 [L,QSA]

# 언어 최상위 - 정적/안내 페이지 (about, privacy, terms, exchanges, coins, rss-guide, sitemap-guide)
RewriteRule ^(en|ja|es|de|fr|pt|tr|vi)/(about|privacy|terms|exchanges|coins|rss-guide|sitemap-guide)/?$ /$2.php?lang=$1 [L,QSA]

